@startuml
actor User
participant ":Parser" as Parser
participant ":Executor" as Exec
participant ":AddInternshipCommand" as Cmd
participant ":InternshipList" as List
participant "existing:Internship" as ExistingIntern
participant "newInternship:Internship" as Intern

User -> Parser : "add Grab /t Software Engineer"
activate Parser
Parser --> Exec : parsed command
deactivate Parser

Exec -> Exec : get command "add"
Exec -> Cmd : execute()
activate Cmd

Cmd -> Parser : getParamsOf(parser.getCommand())
activate Parser
Parser --> Cmd : addParams
deactivate Parser

Cmd -> Parser : getParamsOf("/t")
activate Parser
Parser --> Cmd : titleParams
deactivate Parser

note right of Cmd : Validates presence, length,\nand valid characters

alt invalid inputs
    Cmd -> User : throw GoldenCompassException
else inputs valid
    create Intern
    Cmd -> Intern : new Internship(title, companyName)

    Cmd -> List : add(newInternship)
    activate List

    loop i = 0 to size - 1
        List -> List : get(i)
        activate List
        List --> List : existing
        deactivate List

        List -> ExistingIntern : equals(newInternship)
        activate ExistingIntern
        ExistingIntern --> List : isDuplicate
        deactivate ExistingIntern
    end

    alt duplicate found
        List --> Cmd : throw IllegalArgumentException
        Cmd -> User : throw GoldenCompassException
    else no duplicate
        List --> Cmd : returns successfully
        deactivate List
        Cmd -> Cmd : ui.print("Got it! I've added...")
    end
end

deactivate Cmd
@enduml